# Application
APP_NAME=ai-agent
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
PHOENIX=

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# LLM Provider - OpenAI
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=2048

# Fallback LLM Provider - OpenRouter 
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_MAX_TOKENS=2048

# Mistra for Document Processing (OCR), Fallback Model
MISTRAL_API_KEY=

# Jina AI (Task 7 - Reranking, optional)
JINA_API_KEY=

# Weaviate Cloud (Task 4, optional)
# WEAVIATE_URL=https://xxx.weaviate.network
# WEAVIATE_API_KEY=xxx

# Database (nếu cần)
DATABASE_URL=sqlite:///./data/app.db

# Vector Store (cho RAG, nếu cần)
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./data/chroma

# Langsmith
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT="project_name"

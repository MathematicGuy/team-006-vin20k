# OpenRouter / OpenAI-compatible generation (Task 10)

# Main LLM Provider
OPENAI_API_KEY=
MODEL_ID="gpt-5.4-nano"

# Fallback LLM Provider
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
GOOGLE_API_KEY=

# Mistra for Document Processing (OCR), Fallback Model
MISTRAL_API_KEY=

# Jina AI (for Embedding and Reranking, optional - skip by default)
JINA_API_KEY=

# Weaviate Cloud (VectorDB, optional - skip by default)
# WEAVIATE_URL=https://xxx.weaviate.network
# WEAVIATE_API_KEY=xxx

# Langsmith (optional, optional - skip by default)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT="your_project"